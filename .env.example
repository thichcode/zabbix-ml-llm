# Zabbix connection (required)
ZABBIX_API_URL=https://zabbix.example.com
ZABBIX_USERNAME=api-reader
ZABBIX_PASSWORD=changeme
ZABBIX_VERIFY_SSL=true
ZABBIX_DEFAULT_GROUP=Infrastructure

# Optional tuning
ZABBIX_TREND_ITEM_IDS=10001,10002
ZABBIX_BACKUP_KEYWORDS=backup,snapshot
ZABBIX_USE_MOCK_DATA=true
ZABBIX_REPORT_HORIZON_HOURS=6
ZABBIX_ANOMALY_STD_THRESHOLD=2.0
APP_PORT=8000
LLM_EXPLAINER_URL=
